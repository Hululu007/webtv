<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Default: deny cleartext HTTP. Media/live streams that require HTTP must be
         individually whitelisted via domain-config below. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Local server runs on loopback, HTTP is safe -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- Force HTTPS for config sources, update servers, and remote JAR endpoints -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">cnb.cool</domain>
        <domain includeSubdomains="true">github.com</domain>
        <domain includeSubdomains="true">githubusercontent.com</domain>
        <domain includeSubdomains="true">raw.githubusercontent.com</domain>
        <domain includeSubdomains="true">gitee.com</domain>
    </domain-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
